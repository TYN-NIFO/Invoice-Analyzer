{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "frontend/dist",
  "installCommand": "npm install",
  "rewrites": [
    { "source": "/auth/:path*", "destination": "http://3.111.213.97:8003/auth/:path*" },
    { "source": "/invoices/:path*", "destination": "http://3.111.213.97:8003/invoices/:path*" },
    { "source": "/invoices", "destination": "http://3.111.213.97:8003/invoices" },
    { "source": "/users/:path*", "destination": "http://3.111.213.97:8003/users/:path*" },
    { "source": "/users", "destination": "http://3.111.213.97:8003/users" },
    { "source": "/metrics/:path*", "destination": "http://3.111.213.97:8003/metrics/:path*" },
    { "source": "/logs/:path*", "destination": "http://3.111.213.97:8003/logs/:path*" },
    { "source": "/logs", "destination": "http://3.111.213.97:8003/logs" },
    { "source": "/ingestion/:path*", "destination": "http://3.111.213.97:8003/ingestion/:path*" },
    { "source": "/ingestion-logs", "destination": "http://3.111.213.97:8003/ingestion-logs" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
